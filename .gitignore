# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# --- Environment variables (NEVER commit real secrets) ---
.env
.env.local

# --- Terraform ---
# .tfstate files contain sensitive infra details (IPs, resource IDs) - never commit
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# --- IDE / OS clutter ---
.vscode/
.idea/
.DS_Store

# --- Docker ---
*.log

# --- Kubernetes (local secrets you might generate while testing) ---
k8s/*secret*.yaml
