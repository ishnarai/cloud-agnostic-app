# Copy this file to .env and fill in real values for local development.
# .env is gitignored - never commit real secrets.

# Which cloud provider the app should report as active.
# Valid values: local, aws, azure, gcp
CLOUD_PROVIDER=local

# Display name used in the HTML page.
APP_NAME=Orion

# Port the app listens on.
PORT=8000

# --- Optional: only used if you extend the providers with real cloud calls ---
# AWS_REGION=ap-south-1
# AZURE_REGION=centralindia
# GCP_REGION=asia-south1
